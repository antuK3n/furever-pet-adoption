@model Adopter
@{
    ViewData["Title"] = Model.FullName;
}

<div class="row">
    <h1 class="mb-0">@Model.FullName</h1>
    <div class="actions-cell">
        <a class="btn btn-secondary btn-sm" asp-area="Admin" asp-controller="Adopters"
           asp-action="Edit" asp-route-id="@Model.AdopterId"
           data-modal-url="@Url.Action("Edit", "Adopters", new { area = "Admin", id = Model.AdopterId })">Edit</a>
        <form asp-area="Admin" asp-controller="Adopters" asp-action="Delete"
              asp-route-id="@Model.AdopterId" method="post" class="inline-form"
              data-confirm="Delete @Model.FullName? This also removes their applications and favorites." data-confirm-title="Delete adopter?">
            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
        </form>
    </div>
</div>

<ul class="spec-list">
    <li><span class="label">Email</span><span class="value">@Model.Email</span></li>
    <li><span class="label">Contact</span><span class="value">@Model.ContactNo</span></li>
    <li><span class="label">Address</span><span class="value">@Model.Address</span></li>
    <li><span class="label">Housing</span><span class="value">@Model.HousingType</span></li>
    <li><span class="label">Other pets</span><span class="value">@Model.HasOtherPets</span></li>
    <li><span class="label">Children</span><span class="value">@Model.HasChildren</span></li>
    <li><span class="label">Experience</span><span class="value">@Model.ExperienceLevel</span></li>
</ul>

<section class="section">
    <h2>Applications (@Model.Adoptions.Count)</h2>
    @if (Model.Adoptions.Count > 0)
    {
        <div class="table-wrap">
            <table class="data">
                <thead>
                    <tr>
                        <th>Pet</th>
                        <th>Applied</th>
                        <th>Status</th>
                        <th>Adoption date</th>
                        <th>Fee</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.Adoptions.OrderByDescending(x => x.ApplicationDate))
                    {
                        <tr>
                            <td><partial name="_PetThumbLink" model="a.Pet" /></td>
                            <td>@a.ApplicationDate.ToString("MMM d, yyyy")</td>
                            <td><span class="badge badge-@a.Status.ToLower()">@a.Status</span></td>
                            <td>@(a.AdoptionDate?.ToString("MMM d, yyyy") ?? "—")</td>
                            <td>@(a.AdoptionFee?.ToString("C") ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="muted">No applications yet.</p>
    }
</section>

<section class="section">
    <h2>Favorites (@Model.Favorites.Count)</h2>
    @if (Model.Favorites.Count > 0)
    {
        <ul class="vax-list">
            @foreach (var f in Model.Favorites)
            {
                <li>
                    <partial name="_PetThumbLink" model="f.Pet" />
                    <span class="muted">added @f.DateAdded.ToString("MMM d, yyyy")</span>
                    @if (!string.IsNullOrWhiteSpace(f.Notes))
                    {
                        <span class="muted">— @f.Notes</span>
                    }
                </li>
            }
        </ul>
    }
    else
    {
        <p class="muted">No favorites.</p>
    }
</section>

<a class="btn btn-secondary" asp-area="Admin" asp-controller="Adopters" asp-action="Index">&larr; All adopters</a>
