@model PetFormViewModel
@{
    ViewData["Title"] = $"Edit {Model.Pet.PetName}";
    var isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    if (isAjax) { Layout = null; }
}

@if (isAjax)
{
    <div class="modal-head">
        <h2 class="modal-title">Edit @Model.Pet.PetName</h2>
        <button type="button" class="modal-close" data-modal-close aria-label="Close">&times;</button>
    </div>
    <form asp-area="Admin" asp-controller="Pets" asp-action="Edit" asp-route-id="@Model.Pet.PetId"
          method="post" enctype="multipart/form-data">
        <partial name="_PetForm" />
        <div class="modal-actions">
            <button type="button" class="btn btn-secondary" data-modal-close>Cancel</button>
            <button type="submit" class="btn btn-primary">Save changes</button>
        </div>
    </form>
}
else
{
    <div class="auth-card wide">
        <h1>Edit @Model.Pet.PetName</h1>

        <form asp-area="Admin" asp-controller="Pets" asp-action="Edit" asp-route-id="@Model.Pet.PetId"
              method="post" enctype="multipart/form-data">
            <partial name="_PetForm" />
            <div class="row mt-3">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a class="btn btn-secondary" asp-area="Admin" asp-controller="Pets" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>

    @section Scripts {
        <partial name="/Views/Shared/_ValidationScriptsPartial.cshtml" />
    }
}
