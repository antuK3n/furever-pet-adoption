@model VeterinaryVisit
@{
    var petOptions = (List<Pet>)ViewBag.PetOptions;
}

<div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

<div class="form-grid">
    <div class="form-field">
        <label asp-for="PetId">Pet</label>
        <select asp-for="PetId">
            @foreach (var p in petOptions)
            {
                <option value="@p.PetId">@p.PetName (@p.Species)</option>
            }
        </select>
        <span asp-validation-for="PetId"></span>
    </div>

    <div class="form-field">
        <label asp-for="VisitDate"></label>
        <input asp-for="VisitDate" />
        <span asp-validation-for="VisitDate"></span>
    </div>

    <div class="form-field">
        <label asp-for="VeterinarianName"></label>
        <input asp-for="VeterinarianName" />
        <span asp-validation-for="VeterinarianName"></span>
    </div>

    <div class="form-field">
        <label asp-for="VisitType"></label>
        <select asp-for="VisitType">
            <option value="Checkup">Checkup</option>
            <option value="Vaccination">Vaccination</option>
            <option value="Surgery">Surgery</option>
            <option value="Treatment">Treatment</option>
            <option value="Emergency">Emergency</option>
        </select>
        <span asp-validation-for="VisitType"></span>
    </div>

    <div class="form-field">
        <label asp-for="Weight"></label>
        <input asp-for="Weight" type="number" step="0.01" min="0" />
        <span asp-validation-for="Weight"></span>
    </div>

    <div class="form-field">
        <label asp-for="Temperature"></label>
        <input asp-for="Temperature" type="number" step="0.1" min="0" />
        <span asp-validation-for="Temperature"></span>
    </div>

    <div class="form-field">
        <label asp-for="ProcedureCost"></label>
        <input asp-for="ProcedureCost" type="number" step="0.01" min="0" />
        <span asp-validation-for="ProcedureCost"></span>
    </div>

    <div class="form-field">
        <label asp-for="NextVisitDate"></label>
        <input asp-for="NextVisitDate" />
        <span asp-validation-for="NextVisitDate"></span>
    </div>
</div>

<div class="form-field">
    <label asp-for="Diagnosis"></label>
    <textarea asp-for="Diagnosis" rows="2" placeholder="Leave blank if none"></textarea>
    <span asp-validation-for="Diagnosis"></span>
</div>

<div class="form-field">
    <label asp-for="GeneralNotes"></label>
    <textarea asp-for="GeneralNotes" rows="3"></textarea>
    <span asp-validation-for="GeneralNotes"></span>
</div>
