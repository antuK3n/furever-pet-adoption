@model RegisterViewModel
@{
    ViewData["Title"] = "Create an account";
}

<div class="auth-card wide">
    <h1>Create your account</h1>
    <p class="muted">Tell us a little about your home — it helps us match you with the right pet.</p>

    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly"></div>

        <div class="form-grid">
            <div class="form-group span-2">
                <label class="form-label" asp-for="FullName"></label>
                <input asp-for="FullName" autocomplete="name" />
                <span asp-validation-for="FullName"></span>
            </div>

            <div class="form-group span-2">
                <label class="form-label" asp-for="Email"></label>
                <input asp-for="Email" autocomplete="email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Password"></label>
                <input asp-for="Password" autocomplete="new-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="ContactNo"></label>
                <input asp-for="ContactNo" type="tel" autocomplete="tel" />
                <span asp-validation-for="ContactNo"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="HousingType"></label>
                <select asp-for="HousingType">
                    <option>House</option>
                    <option>Apartment</option>
                    <option>Condo</option>
                    <option>Farm</option>
                </select>
                <span asp-validation-for="HousingType"></span>
            </div>

            <div class="form-group span-2">
                <label class="form-label" asp-for="Address"></label>
                <input asp-for="Address" autocomplete="street-address" />
                <span asp-validation-for="Address"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="HasOtherPets"></label>
                <select asp-for="HasOtherPets">
                    <option>No</option>
                    <option>Yes</option>
                </select>
                <span asp-validation-for="HasOtherPets"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="HasChildren"></label>
                <select asp-for="HasChildren">
                    <option>No</option>
                    <option>Yes</option>
                </select>
                <span asp-validation-for="HasChildren"></span>
            </div>

            <div class="form-group span-2">
                <label class="form-label" asp-for="ExperienceLevel"></label>
                <select asp-for="ExperienceLevel">
                    <option>First-time</option>
                    <option>Experienced</option>
                </select>
                <span asp-validation-for="ExperienceLevel"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-primary w-full">Create account</button>
    </form>

    <p class="text-sm mt-4 mb-0">
        Already have an account? <a asp-action="Login">Log in</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
